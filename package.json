{
  "name": "bc",
  "version": "1.0.0",
  "description": "Sistema de gestión de base de conocimiento para agentes conversacionales",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:prod": "wrangler deploy --env production",
    "db:migrate": "wrangler d1 execute bc-db --file=./src/db/schema.sql",
    "db:migrate:local": "wrangler d1 execute bc-db --local --file=./src/db/schema.sql",
    "db:migrate:prod": "wrangler d1 execute bc-db --remote --file=./src/db/schema.sql",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.0",
    "hono": "^4.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.0.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.45.3"
  }
}
